@inherits LayoutComponentBase
@inject IJSRuntime JS

<RadzenLayout>
    <RadzenDialog />
    <RadzenNotification />
    <RadzenTooltip />
    <RadzenContextMenu />
    
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0" Style="width:100%; justify-content: space-between;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0">
                <RadzenSidebarToggle Click="@(() => sidebar1Expanded = !sidebar1Expanded)" />
                <RadzenLabel Text="Web File Explorer" />
            </RadzenStack>
            <RadzenButton Icon="@(_isDarkMode ? "light_mode" : "dark_mode")" 
                          Click="@ToggleDarkMode" 
                          ButtonStyle="ButtonStyle.Light" 
                          title="@(_isDarkMode ? "Switch to Light Mode" : "Switch to Dark Mode")"
                          Style="margin-right: 1rem;" />
        </RadzenStack>
    </RadzenHeader>
    <RadzenSidebar @bind-Expanded="@sidebar1Expanded">
        <RadzenPanelMenu>
            <RadzenPanelMenuItem Text="Home" Icon="home" Path="/" />
            <RadzenPanelMenuItem Text="Recycle Bin" Icon="delete" Path="/?path=::RecycleBin::" />
        </RadzenPanelMenu>
    </RadzenSidebar>
    <RadzenBody>
        <div class="rz-p-2" style="height: 100%; display: flex; flex-direction: column;">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>

<RadzenComponents />

@code {
    bool sidebar1Expanded = true;
    bool _isDarkMode = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var saved = await JS.InvokeAsync<string>("localStorage.getItem", "darkMode");
                if (saved == "false")
                {
                    _isDarkMode = false;
                    await JS.InvokeVoidAsync("eval", "document.querySelector('link[href*=\"Radzen.Blazor/css\"]').href = '_content/Radzen.Blazor/css/standard.css'");
                    await JS.InvokeVoidAsync("eval", "document.body.classList.remove('dark-mode')");
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        if (_isDarkMode)
        {
            await JS.InvokeVoidAsync("eval", "document.querySelector('link[href*=\"Radzen.Blazor/css\"]').href = '_content/Radzen.Blazor/css/standard-dark.css'");
            await JS.InvokeVoidAsync("eval", "document.body.classList.add('dark-mode')");
            await JS.InvokeVoidAsync("localStorage.setItem", "darkMode", "true");
        }
        else
        {
            await JS.InvokeVoidAsync("eval", "document.querySelector('link[href*=\"Radzen.Blazor/css\"]').href = '_content/Radzen.Blazor/css/standard.css'");
            await JS.InvokeVoidAsync("eval", "document.body.classList.remove('dark-mode')");
            await JS.InvokeVoidAsync("localStorage.setItem", "darkMode", "false");
        }
    }
}

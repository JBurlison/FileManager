    private async Task PerformExtract(string zipPath, string destPath, ConflictResolution resolution)
    {
            var request = new ExtractRequest
            {
                ZipPath = zipPath,
                DestinationFolderPath = destPath,
                Resolution = resolution
            };

            _isLoading = true;
            StateHasChanged();
            try
            {
                var response = await Http.PostAsJsonAsync("api/fileexplorer/extract", request);
                if (response.IsSuccessStatusCode)
                {
                    NotificationService.Notify(NotificationSeverity.Success, "Extracted", $"Successfully extracted.");
                    await LoadDirectoryAsync(_currentPath!);
                }
                else
                {
                    var error = await response.Content.ReadFromJsonAsync<Result>();
                    var errMsg = error?.ErrorMessage ?? "Failed to extract zip file.";

                    if (resolution == ConflictResolution.None && errMsg.Contains("already exist"))
                    {
                        _isLoading = false;
                        StateHasChanged();
                        var chosenResolution = await ShowConflictResolutionDialog();
                        if (chosenResolution.HasValue && chosenResolution.Value != ConflictResolution.None)
                        {
                            await PerformExtract(zipPath, destPath, chosenResolution.Value);
                        }
                        return;
                    }

                    NotificationService.Notify(NotificationSeverity.Error, "Error", errMsg);
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
    }

    private async Task DeleteSelected(bool permanent = false)
    {
        if (!CanDelete) return;

        var itemsToDelete = _selectedItems.Count > 0 ? _selectedItems.ToList() : new List<FileSystemItem> { _focusedItem! };
        
        var title = permanent ? "Permanently Delete Items" : "Delete Items";
        var confirmMsg = "";
        
        if (permanent || IsRecycleBin)
        {
            var word = IsRecycleBin ? "permanently delete" : "delete";
            confirmMsg = itemsToDelete.Count == 1 
                ? $"Are you sure you want to {word} '{itemsToDelete[0].Name}'?" 
                : $"Are you sure you want to {word} {itemsToDelete.Count} items?";
        }
        else
        {
            confirmMsg = itemsToDelete.Count == 1 
                ? $"Are you sure you want to move '{itemsToDelete[0].Name}' to the Recycle Bin?" 
                : $"Are you sure you want to move {itemsToDelete.Count} items to the Recycle Bin?";
        }

        var options = new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" };
        var confirmed = await DialogService.Confirm(confirmMsg, title, options);

        if (confirmed == true)
        {
            _isLoading = true;
            StateHasChanged();

            try
            {
                int successCount = 0;
                int failedCount = 0;
                foreach (var item in itemsToDelete)
                {
                    var success = await DeleteAsync(item.FullPath, permanent || IsRecycleBin);
                    if (success) successCount++;
                    else failedCount++;
                }

                if (successCount > 0)
                {
                    NotificationService.Notify(NotificationSeverity.Success, "Deleted", $"Successfully deleted {successCount} item(s).");
                    await LoadDirectoryAsync(_currentPath!);
                }
                if (failedCount > 0)
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Delete Failed", $"{failedCount} item(s) failed.");
                }
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task<bool> DeleteAsync(string path, bool permanent)
    {
        try
        {
            HttpResponseMessage response;
            if (IsRecycleBin)
            {
                response = await Http.PostAsync($"api/fileexplorer/recyclebin/delete?id={Uri.EscapeDataString(path)}", null);
            }
            else
            {
                var uri = $"api/fileexplorer/delete?path={Uri.EscapeDataString(path)}&permanent={permanent.ToString().ToLower()}";
                response = await Http.DeleteAsync(uri);
            }
            
            if (response.IsSuccessStatusCode)
            {
                return true;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<Result>();
                NotificationService.Notify(NotificationSeverity.Error, "Delete Failed", error?.ErrorMessage ?? $"Failed to delete '{GetFileName(path)}'.");
                return false;
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Delete Failed", ex.Message);
            return false;
        }
    }

        private bool CanCut => _selectedItems.Any();
    private bool CanCopy => _selectedItems.Any();
    private bool CanPaste => !string.IsNullOrEmpty(_currentPath) && Clipboard.Items.Any();

    private bool IsGhosted(FileSystemItem item) 
    {
        bool isClipboardCut = Clipboard.IsCut && Clipboard.Items.Any(p => string.Equals(p, item.FullPath, StringComparison.OrdinalIgnoreCase));
        bool isDragged = _draggedItems.Any(p => string.Equals(p, item.FullPath, StringComparison.OrdinalIgnoreCase));
        return isClipboardCut || isDragged;
    }

    private void CutSelected() => Clipboard.SetState(true, _selectedItems.Select(x => x.FullPath), _currentPath ?? string.Empty);
    private void CopySelected() => Clipboard.SetState(false, _selectedItems.Select(x => x.FullPath), _currentPath ?? string.Empty);

    private async Task PasteItems()
    {
        await PerformPasteItems(_currentPath ?? string.Empty, Clipboard.IsCut, Clipboard.Items, ConflictResolution.None);
    }

    private async Task PerformPasteItems(string destinationPath, bool isCut, IEnumerable<string> sourcePaths, ConflictResolution resolution)
    {
        if (!sourcePaths.Any() || string.IsNullOrEmpty(destinationPath)) return;
        
        _isLoading = true;
        StateHasChanged();

        try
        {
            var request = new ClipboardOperationRequest { 
                Items = sourcePaths, 
                DestinationPath = destinationPath, 
                Overwrite = resolution == ConflictResolution.Overwrite,
                Resolution = resolution 
            };
            var endpoint = isCut ? "api/fileexplorer/move" : "api/fileexplorer/copy";
            
            var response = await Http.PostAsJsonAsync(endpoint, request);
            var result = await response.Content.ReadFromJsonAsync<Result>();

            if (response.IsSuccessStatusCode && result != null && result.IsSuccess)
            {
                if (isCut) Clipboard.Clear();
                
                // Re-load the directory and optionally select newly pasted items
                _postLoadSelectionPaths = sourcePaths.Select(p => 
                    CombinePaths(destinationPath, GetFileName(p))).ToList();
                    
                await LoadDirectoryAsync(_currentPath ?? string.Empty);
            }
            else
            {
                var errMsg = result?.ErrorMessage ?? "Operation failed.";
                if (result?.Errors != null && result.Errors.Any())
                {
                    errMsg += $" ({result.FailedCount} failed)";
                }

                if (resolution == ConflictResolution.None && errMsg.Contains("already exists"))
                {
                    _isLoading = false;
                    StateHasChanged();
                    // Call dialog before reloading
                    var chosenResolution = await ShowConflictResolutionDialog();
                    if (chosenResolution != null)
                    {
                        // We must reset isLoading while waiting for the nested task, or recursive call is sufficient. Wait, recursive call will handle it, but we already have a finally.
                        // Actually, we should just let the nested method's finally handle its own state, but ours will run too. It's fine.
                        await PerformPasteItems(destinationPath, isCut, sourcePaths, chosenResolution.Value);
                        return;
                    }
                }
                else
                {
                    _errorMessage = errMsg;
                    NotificationService.Notify(NotificationSeverity.Error, "Operation Failed", _errorMessage, 6000D);
                    if (result?.Errors != null && result.Errors.Any())
                    {
                        var limitedErrors = result.Errors.Take(3).Select(e => e.Value).ToList();
                        var errorDetails = string.Join("\n", limitedErrors) + (result.Errors.Count > 3 ? $"\n...and {result.Errors.Count - 3} more." : "");
                        NotificationService.Notify(NotificationSeverity.Error, "Error Details", errorDetails, 10000D);
                    }
                }
                if (result?.SuccessfulCount > 0) await LoadDirectoryAsync(_currentPath ?? string.Empty);
            }
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task<ConflictResolution?> ShowConflictResolutionDialog()
    {
        var result = await DialogService.OpenAsync("File Conflict", ds =>
            @<RadzenStack Gap="1.5rem">
                <p>Destination item already exists. How do you want to proceed?</p>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.Center">
                    <RadzenButton Text="Overwrite" Click="@(() => ds.Close(ConflictResolution.Overwrite))" ButtonStyle="ButtonStyle.Primary" Style="width: 100px" />
                    <RadzenButton Text="Merge" Click="@(() => ds.Close(ConflictResolution.Merge))" ButtonStyle="ButtonStyle.Secondary" Style="width: 100px" />
                    <RadzenButton Text="Skip" Click="@(() => ds.Close(ConflictResolution.Skip))" ButtonStyle="ButtonStyle.Warning" Style="width: 100px" />
                    <RadzenButton Text="Cancel" Click="@(() => ds.Close(null))" ButtonStyle="ButtonStyle.Light" Style="width: 100px" />
                </RadzenStack>
            </RadzenStack>);

        return result as ConflictResolution?;
    }

    private void OnDragStart(DragEventArgs e, FileSystemItem item)
    {
        if (!_selectedItems.Contains(item))
        {
            _selectedItems.Clear();
            _selectedItems.Add(item);
        }
        _draggedItems = _selectedItems.Select(x => x.FullPath).ToList();
    }

    private void OnDragEnd()
    {
        _draggedItems.Clear();
    }

    private async Task OnDrop(DragEventArgs e, FileSystemItem targetItem)
    {
        if (targetItem.Type != FileSystemItemType.Folder || !_draggedItems.Any())
        {
            _draggedItems.Clear();
            return;
        }

        if (_draggedItems.Any(p => string.Equals(p, targetItem.FullPath, StringComparison.OrdinalIgnoreCase)))
        {
            _draggedItems.Clear();
            return;
        }

        var itemsToMove = _draggedItems.ToList();
        _draggedItems.Clear();
        await PerformPasteItems(targetItem.FullPath, true, itemsToMove, ConflictResolution.None);
    }

    protected override void OnInitialized()
    {
        Clipboard.OnChange += StateHasChanged;
        base.OnInitialized();
    }

    public void Dispose()
    {
        CancelSearch();
        Clipboard.OnChange -= StateHasChanged;
        try
        {
            _lifetimeCts.Cancel();
        }
        catch { }
        _lifetimeCts.Dispose();
    }

    private void ClearSelection()
    {
        _selectedItems.Clear();
        _focusedItem = null;
        _lastClickedItem = null;
    }


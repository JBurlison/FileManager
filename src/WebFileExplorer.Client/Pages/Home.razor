@page "/"
@implements IDisposable
@using WebFileExplorer.Shared.Models
@using Microsoft.Extensions.Logging
@inject HttpClient Http
@inject ILogger<Home> Logger
@inject IJSRuntime JS
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject ContextMenuService ContextMenuService
@inject WebFileExplorer.Client.Services.ClipboardStateContainer Clipboard
@inject NavigationManager NavigationManager

<PageTitle>Web File Explorer</PageTitle>

<div class="command-bar-row mb-3" role="toolbar" aria-label="Action Toolbar">
    <RadzenButton Text="New Folder" Icon="create_new_folder" Click="@CreateFolderDialog" Disabled="@(string.IsNullOrEmpty(_currentPath))" Class="rz-mr-2" ButtonStyle="ButtonStyle.Primary" aria-label="Create New Folder" />
    <RadzenButton Text="Rename" Icon="edit" Click="@RenameDialog" Disabled="@(!CanRename)" Class="rz-mr-2" ButtonStyle="ButtonStyle.Light" aria-label="Rename Selected Item" />
    <RadzenButton Text="Delete" Icon="delete" Click="@(args => DeleteSelected(false))" Disabled="@(!CanDelete)" Class="rz-mr-4" ButtonStyle="ButtonStyle.Danger" aria-label="Delete Selected Items" />

    <RadzenButton Text="Restore" Icon="restore" Click="@RestoreSelected" Disabled="@(!CanRestore)" Class="rz-mr-2" ButtonStyle="ButtonStyle.Success" aria-label="Restore Selected Items" />
    <RadzenButton Text="Empty Bin" Icon="delete_forever" Click="@EmptyRecycleBin" Disabled="@(!IsRecycleBin)" Class="rz-mr-4" ButtonStyle="ButtonStyle.Danger" aria-label="Empty Recycle Bin" />

    <RadzenButton Text="Cut" Icon="content_cut" Click="@CutSelected" Disabled="@(!CanCut)" Class="rz-mr-2" ButtonStyle="ButtonStyle.Light" aria-label="Cut Selected Items" />
    <RadzenButton Text="Copy" Icon="content_copy" Click="@CopySelected" Disabled="@(!CanCopy)" Class="rz-mr-2" ButtonStyle="ButtonStyle.Light" aria-label="Copy Selected Items" />
    <RadzenButton Text="Paste" Icon="content_paste" Click="@PasteItems" Disabled="@(!CanPaste)" Class="rz-mr-2" ButtonStyle="ButtonStyle.Light" aria-label="Paste Items" />
    <RadzenButton Text="Compress" Icon="folder_zip" Click="@CompressSelected" Disabled="@(!CanCompress)" Class="rz-mr-2" ButtonStyle="ButtonStyle.Light" title="Compress to ZIP file" aria-label="Compress Selected Items to ZIP" />
    <RadzenButton Text="Extract" Icon="unarchive" Click="@(args => ExtractSelected(GetSingleZipItem()))" Disabled="@(!CanExtract)" Class="rz-mr-4" ButtonStyle="ButtonStyle.Light" title="Extract All" aria-label="Extract Selected ZIP" />

    <div class="wfe-breadcrumb-container d-flex align-items-center" style="flex: 1;">
        <RadzenButton Icon="arrow_upward" Click="@NavigateUp" Disabled="@(string.IsNullOrEmpty(_currentPath))" Class="rz-mr-2" title="Up" aria-label="Navigate Up" />
        <RadzenTextBox @bind-Value="@_addressInput" style="flex: 1" class="rz-mr-2" @onkeyup="@OnAddressKeyUp" aria-label="Address" />
        <RadzenButton Icon="keyboard_return" Click="@NavigateToAddress" title="Go" Class="rz-mr-4" />
    </div>

    <RadzenTextBox @bind-Value="@_searchInput" class="rz-mr-2" Placeholder="Search..." @onkeyup="@OnSearchKeyUp" style="width: 150px;" Disabled="@(string.IsNullOrEmpty(_currentPath))" aria-label="Search items" />
    <RadzenCheckBox @bind-Value=@_searchSubfolders Name="cbSearchSubfolders" Class="rz-mr-2" />
    <RadzenLabel Text="Subfolders" Component="cbSearchSubfolders" Class="rz-mr-2" />
    @if (_isSearching)
    {
        <RadzenButton Icon="cancel" Click="@CancelSearch" title="Cancel Search" aria-label="Cancel Search" Class="rz-mr-4" ButtonStyle="ButtonStyle.Danger" />
    }
    else
    {
        <RadzenButton Icon="search" Click="@PerformSearch" title="Search" aria-label="Search" Class="rz-mr-4" Disabled="@(string.IsNullOrEmpty(_currentPath) || string.IsNullOrWhiteSpace(_searchInput))" />
    }

    <RadzenSelectBar @bind-Value=@_viewMode TValue="string" Class="rz-mr-4" Change=@( (string args) => OnViewModeChanged(args) ) aria-label="Select View Mode">
        <Items>
            <RadzenSelectBarItem Text="Details" Value="@("Details")" Icon="view_list" />
            <RadzenSelectBarItem Text="List" Value="@("List")" Icon="format_list_bulleted" />
            <RadzenSelectBarItem Text="Small Icons" Value="@("SmallIcons")" Icon="view_module" />
            <RadzenSelectBarItem Text="Medium Icons" Value="@("MediumIcons")" Icon="view_module" />
            <RadzenSelectBarItem Text="Large Icons" Value="@("LargeIcons")" Icon="view_module" />
        </Items>
    </RadzenSelectBar>

    <RadzenCheckBox @bind-Value=@_showHidden Name="cbHidden" Change=@( (bool args) => OnShowHiddenChanged(args) ) />
    <RadzenLabel Text="Hidden Items" Component="cbHidden" Class="rz-ml-2" />
</div>

<RadzenSplitter Orientation="Orientation.Horizontal" class="wfe-splitter">
    <RadzenSplitterPane Size="250px" Min="150px" Max="500px">
        <div style="padding: 1rem; overflow: auto; height: 100%;">
            <RadzenText TextStyle="TextStyle.Subtitle2" Class="mb-3">This PC</RadzenText>
            @if (_roots == null)
            {
                <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            }
            else
            {
                <div class="tree-container" style="width: 100%;">
                    @foreach (var node in _treeNodes)
                    {
                        <TreeNodeComponent Node="@node" 
                                          ExpandedNodes="@_expandedNodes" 
                                          SelectedNode="@_selectedTreeNode"
                                          OnNodeClick="@OnTreeNodeClick"
                                          OnNodeToggle="@OnTreeNodeToggle" />
                    }
                </div>
            }
        </div>
    </RadzenSplitterPane>
    <RadzenSplitterPane>
        <div style="padding: 1rem; height: 100%; display: flex; flex-direction: column;">
            <div class="mb-3">
                <RadzenBreadCrumb>
                    <RadzenBreadCrumbItem Text="This PC" @onclick="@(() => { _currentPath = null; _currentItems = null; _addressInput = ""; UpdateBreadcrumbs(); StateHasChanged(); })" Style="cursor:pointer;" />
                    @foreach (var crumb in _breadcrumbs)
                    {
                        var path = crumb.FullPath;
                        <RadzenBreadCrumbItem Text="@crumb.Name" @onclick="@(() => LoadDirectoryAsync(path))" Style="cursor:pointer;" />
                    }
                </RadzenBreadCrumb>
            </div>
            
            <div style="flex: 1; overflow: auto;">
                @if (_isLoading)
                {
                    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                }
                else if (_errorMessage != null)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false" ShowIcon="true">
                        @_errorMessage
                    </RadzenAlert>
                }
                else if (_currentItems != null)
                {
                    <div id="file-container" style="height: 100%;" tabindex="0" 
                         role="region" aria-label="File List"
                         @onkeydown="OnKeyDown"
                         @oncontextmenu="OnContainerContextMenu"
                         @oncontextmenu:preventDefault="true">
                        @if (_viewMode == "Details")
                        {
                            <RadzenDataGrid @ref="_dataGrid" Data="@_currentItems"   TItem="FileSystemItem" 
                                RowDoubleClick="@OnRowDoubleClick" RowSelect="@OnRowSelect"
                                RowRender="@OnRowRender"
                                AllowSorting="true" Style="height: 100%"
                                AllowVirtualization="true"
                                SelectionMode="DataGridSelectionMode.Multiple"
                                @bind-Value=@_selectedItems>
                                <Columns>
                                    <RadzenDataGridColumn TItem="FileSystemItem" Property="Name" Title="Name">
                                        <Template Context="item">
                                            <div draggable="true" 
                                                 @ondragstart="@(e => OnDragStart(e, item))"
                                                 @ondrop="@(e => OnDrop(e, item))"
                                                 @ondragend="OnDragEnd"
                                                 @ondragover:preventDefault
                                                 @ondragenter:preventDefault
                                                 class="@(IsGhosted(item) ? "item-ghosted" : "")"
                                                 style="display: flex; align-items: center;">
                                                <RadzenIcon Icon="@GetIconForItem(item)" Class="@($"rz-mr-1 {GetIconClass(item)}")" />
                                                @item.Name
                                            </div>
                                        </Template>
                                    </RadzenDataGridColumn>
                                    @if (_isSearchResults)
                                    {
                                        <RadzenDataGridColumn TItem="FileSystemItem" Property="FullPath" Title="Location">
                                            <Template Context="item">
                                                @(GetDirectoryName(item.FullPath))
                                            </Template>
                                        </RadzenDataGridColumn>
                                    }
                                    @if (IsRecycleBin)
                                    {
                                        <RadzenDataGridColumn TItem="FileSystemItem" Property="OriginalPath" Title="Original Path" />
                                        <RadzenDataGridColumn TItem="FileSystemItem" Property="DeletionTime" Title="Date Deleted" FormatString="{0:g}" />
                                    }
                                    else
                                    {
                                        <RadzenDataGridColumn TItem="FileSystemItem" Property="LastModified" Title="Date Modified" FormatString="{0:g}" />
                                    }
                                    <RadzenDataGridColumn TItem="FileSystemItem" Property="Type" Title="Type" />
                                    <RadzenDataGridColumn TItem="FileSystemItem" Property="Size" Title="Size">
                                        <Template Context="item">
                                            @(item.Type == FileSystemItemType.Folder ? "" : FormatSize(item.Size))
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        }
                        else
                        {
                            <div class="custom-view-container @(_viewMode.ToLower())" @onclick="ClearSelection" role="grid" aria-label="File Items">
                                <Virtualize Items="@_currentItems.ToList()" Context="item">
                                    @{
                                        bool isSelected = _selectedItems.Contains(item) || (_focusedItem == item && _selectedItems.Count == 0);
                                        bool isFocused = _focusedItem == item;
                                    }
                                    <div class="custom-view-item @(isSelected ? "selected" : "") @(isFocused ? "focused" : "") @(IsGhosted(item) ? "item-ghosted" : "")"
                                         role="row"
                                         aria-selected="@(isSelected ? "true" : "false")"
                                         aria-label="@($"{item.Name}, {(item.Type == FileSystemItemType.Folder ? "Folder" : "File")}, {(item.Type == FileSystemItemType.Folder ? "" : FormatSize(item.Size))}")"
                                         draggable="true"
                                         @ondragstart="@(e => OnDragStart(e, item))"
                                         @ondrop="@(e => OnDrop(e, item))"
                                         @ondragend="OnDragEnd"
                                         @ondragover:preventDefault
                                         @ondragenter:preventDefault
                                         @onclick="(e) => OnItemClick(e, item)"
                                         @ondblclick="() => OnItemDoubleClick(item)"
                                         @oncontextmenu="@(e => OnContextMenu(e, item))"
                                         @oncontextmenu:preventDefault="true"
                                         @onclick:stopPropagation="true">
                                        @if (IsImageFile(item) && (_viewMode == "LargeIcons" || _viewMode == "MediumIcons"))
                                        {
                                            <img src="@($"api/fileexplorer/download?path={Uri.EscapeDataString(item.FullPath)}&inline=true")" 
                                                 class="item-thumbnail" alt="@item.Name" loading="lazy" />
                                        }
                                        else
                                        {
                                            <RadzenIcon Icon="@GetIconForItem(item)" Class="@($"item-icon {GetIconClass(item)}")" />
                                        }
                                        <span class="item-name">@item.Name</span>
                                    </div>
                                </Virtualize>
                            </div>
                        }
                    </div>
                }
            </div>
            @if (_currentItems != null)
            {
                <div class="status-bar d-flex align-items-center p-2 bg-light border-top" style="flex-shrink: 0;">
                    <span class="rz-mr-4">@_currentItems.Count() items</span>
                    @if (_selectedItems.Count > 0)
                    {
                        <span>@_selectedItems.Count items selected (@FormatSize(_selectedItems.Sum(i => i.Size)))</span>
                    }
                </div>
            }
        </div>
    </RadzenSplitterPane>
</RadzenSplitter>

@code {
    private const int ColumnsSmallIcons = 6;
    private const int ColumnsMediumIcons = 4;
    private const int ColumnsLargeIcons = 3;
    private const int ColumnsDefaultList = 1;

    private IEnumerable<DriveItem>? _roots;
    private IEnumerable<FileSystemItem>? _currentItems;
    private string? _currentPath;
    private string _addressInput = "";
    private bool _isLoading = false;
    private string? _errorMessage = null;

    private string _viewMode = "Details";
    private bool _showHidden = false;
    
    private string _searchInput = "";
    private bool _isSearching = false;
    private bool _isSearchResults = false;
    private bool _searchSubfolders = true;
    private System.Threading.CancellationTokenSource? _searchCts;
    private readonly System.Threading.CancellationTokenSource _lifetimeCts = new();
    
    private RadzenDataGrid<FileSystemItem>? _dataGrid;
    private IList<FileSystemItem> _selectedItems = new List<FileSystemItem>();
    private FileSystemItem? _focusedItem;
    private FileSystemItem? _lastClickedItem;

    private bool _needsKeyboardRegistration = false;
    private List<(string Name, string FullPath)> _breadcrumbs = new();
    private List<string> _draggedItems = new();
    private List<string> _postLoadSelectionPaths = new();
    private string? _pendingSortProperty;
    private int? _pendingSortOrder;
    private double? _pendingScrollPosition;
    
    private List<string> _history = new();
    private int _historyIndex = -1;
    private string _typeBuffer = "";
    private DateTime _lastTypeTime = DateTime.MinValue;

    private RadzenTree? _tree;
    private HashSet<string> _expandedNodes = new(StringComparer.OrdinalIgnoreCase);

    [Parameter]
    [SupplyParameterFromQuery]
    public string? Path { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (Path != null && _currentPath != Path)
        {
            await LoadDirectoryAsync(Path);
            _addressInput = Path;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var roots = await Http.GetFromJsonAsync<IEnumerable<DriveItem>>("api/fileexplorer/roots");
            var rootsList = roots?.ToList() ?? new List<DriveItem>();
            rootsList.Add(new DriveItem("Recycle Bin", "::RecycleBin::", 0, 0));
            _roots = rootsList;

            _treeNodes = rootsList.Select(r => new TreeNodeObj
            {
                Name = r.Name,
                Path = r.RootDirectory,
                IsDrive = true
            }).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching roots: {Message}", ex.Message);
            _roots = Array.Empty<DriveItem>();
            _treeNodes = new();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && string.IsNullOrEmpty(Path) && string.IsNullOrEmpty(_currentPath))
        {
            try
            {
                var stateJson = await JS.InvokeAsync<string>("sessionStorage.getItem", "fileExplorerState");
                if (!string.IsNullOrEmpty(stateJson))
                {
                    var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                    var state = System.Text.Json.JsonSerializer.Deserialize<ExplorerState>(stateJson, options);
                    if (state != null)
                    {
                        if (!string.IsNullOrEmpty(state.ViewMode)) _viewMode = state.ViewMode;
                        _showHidden = state.ShowHidden;
                        
                        if (state.History != null)
                        {
                            _history = state.History;
                            _historyIndex = state.HistoryIndex;
                        }

                        if (!string.IsNullOrEmpty(state.LastPath))
                        {
                            if (state.SelectedPaths != null && state.SelectedPaths.Any())
                            {
                                _postLoadSelectionPaths = state.SelectedPaths;
                            }
                            _pendingSortProperty = state.SortProperty;
                            _pendingSortOrder = state.SortOrder;
                            _pendingScrollPosition = state.ScrollPosition;
                            await LoadDirectoryAsync(state.LastPath);
                        }
                    }
                }
                else
                {
                    var lastPath = await JS.InvokeAsync<string>("sessionStorage.getItem", "lastPath");
                    if (!string.IsNullOrEmpty(lastPath))
                    {
                        await LoadDirectoryAsync(lastPath);
                    }
                }
            }
            catch { }
        }

        if (_needsKeyboardRegistration && _currentItems != null)
        {
            _needsKeyboardRegistration = false;
            try 
            {
                await JS.InvokeVoidAsync("registerKeyboardInterceptor", "file-container");
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to register keyboard interceptor.");
            }
        }
    }

    private class ExplorerState
    {
        public string? LastPath { get; set; }
        public string? ViewMode { get; set; }
        public bool ShowHidden { get; set; }
        public List<string> SelectedPaths { get; set; } = new();
        public List<string> History { get; set; } = new();
        public int HistoryIndex { get; set; } = -1;
        public string? SortProperty { get; set; }
        public int? SortOrder { get; set; }
        public double ScrollPosition { get; set; }
    }

    private async Task SaveStateAsync()
    {
        try
        {
            var sortCol = _dataGrid?.ColumnsCollection?.FirstOrDefault(c => c.GetSortOrder() != null);
            double scrollPos = 0;
            if (_viewMode == "List")
            {
               try { scrollPos = await JS.InvokeAsync<double>("eval", "document.querySelector('.rz-data-grid-data')?.scrollTop || 0"); } catch { }
            }
            else 
            {
               try { scrollPos = await JS.InvokeAsync<double>("eval", "document.getElementById('file-container')?.scrollTop || 0"); } catch { }
            }

            var state = new ExplorerState
            {
                LastPath = _currentPath,
                ViewMode = _viewMode,
                ShowHidden = _showHidden,
                SelectedPaths = _selectedItems.Select(i => i.FullPath).ToList(),
                History = _history,
                HistoryIndex = _historyIndex,
                SortProperty = sortCol?.Property,
                SortOrder = sortCol?.GetSortOrder() != null ? (int)sortCol.GetSortOrder() : null,
                ScrollPosition = scrollPos
            };
            var json = System.Text.Json.JsonSerializer.Serialize(state);
            await JS.InvokeVoidAsync("sessionStorage.setItem", "fileExplorerState", json);
            await JS.InvokeVoidAsync("sessionStorage.setItem", "lastPath", _currentPath);
        }
        catch { }
    }

    private async Task OnRowDoubleClick(DataGridRowMouseEventArgs<FileSystemItem> args)
    {
        if (args.Data?.Type == FileSystemItemType.Folder)
        {
            await LoadDirectoryAsync(args.Data.FullPath!);
        }
        else if (args.Data?.Type == FileSystemItemType.File)
        {
            await PreviewOrDownload(args.Data);
        }
    }

    private async Task OnAddressKeyUp(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await NavigateToAddress();
        }
    }

    private async Task OnSearchKeyUp(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchInput) && !string.IsNullOrEmpty(_currentPath))
        {
            await PerformSearch();
        }
    }

    private async Task PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchInput) || string.IsNullOrEmpty(_currentPath)) return;

        CancelSearch();

        var cts = new System.Threading.CancellationTokenSource();
        _searchCts = cts;
        var token = cts.Token;

        _isLoading = true;
        _isSearching = true;
        _isSearchResults = true;
        _errorMessage = null;
        _currentItems = new List<FileSystemItem>();
        ClearSelection();
        StateHasChanged();

        try
        {
            var uri = $"api/fileexplorer/search?path={Uri.EscapeDataString(_currentPath)}&q={Uri.EscapeDataString(_searchInput)}&showHidden={_showHidden}&recurse={_searchSubfolders}";
            var response = await Http.GetAsync(uri, token);

            if (response.IsSuccessStatusCode)
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var result = await response.Content.ReadFromJsonAsync<WebFileExplorer.Shared.Models.PagedResult<FileSystemItem>>(options, cancellationToken: token);
                var deserialized = result?.Items;
                _currentItems = deserialized?.OrderBy(i => i.Type != FileSystemItemType.Folder).ThenBy(i => i.Name).ToList();
            }
            else
            {
                if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
                    _errorMessage = "Access Denied: You are not authorized to access this directory.";
                else if ((int)response.StatusCode == 499)
                {
                    if (!string.IsNullOrEmpty(_currentPath)) {
                        await LoadDirectoryAsync(_currentPath);
                        _errorMessage = "Search cancelled.";
                    }
                }
                else
                    _errorMessage = $"Error: {response.StatusCode}";
            }
        }
        catch (TaskCanceledException)
        {
            if (!string.IsNullOrEmpty(_currentPath)) {
                await LoadDirectoryAsync(_currentPath);
                _errorMessage = "Search cancelled.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to perform search in {Path}", _currentPath);
            _errorMessage = "An unexpected error occurred while searching.";
        }
        finally
        {
            _isLoading = false;
            _isSearching = false;
            
            if (_searchCts == cts)
            {
                _searchCts.Dispose();
                _searchCts = null;
            }
            
            StateHasChanged();
        }
    }

    private void CancelSearch()
    {
        if (_searchCts != null)
        {
            _searchCts.Cancel();
            _searchCts.Dispose();
            _searchCts = null;
        }
        _isSearching = false;
    }

    private async Task NavigateToAddress()
    {
        if (!string.IsNullOrWhiteSpace(_addressInput))
        {
            await LoadDirectoryAsync(_addressInput);
        }
    }

    private async Task NavigateUp()
    {
        if (!string.IsNullOrEmpty(_currentPath))
        {
            try
            {
                var parentPath = GetDirectoryName(_currentPath);
                if (string.IsNullOrEmpty(parentPath) || parentPath == _currentPath)
                {
                    _currentPath = null;
                    _currentItems = null;
                    _addressInput = "";
                    UpdateBreadcrumbs();
                    return;
                }
                await LoadDirectoryAsync(parentPath);
                return;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to navigate up from {Path}", _currentPath);
            }
            
            // Fallback if unable to determine parent
            _currentPath = null;
            _currentItems = null;
            _addressInput = "";
            UpdateBreadcrumbs();
        }
    }

    private async Task NavigateBack()
    {
        if (_historyIndex > 0)
        {
            _historyIndex--;
            await LoadDirectoryInternalAsync(_history[_historyIndex], false);
        }
    }

    private async Task NavigateForward()
    {
        if (_historyIndex >= 0 && _historyIndex < _history.Count - 1)
        {
            _historyIndex++;
            await LoadDirectoryInternalAsync(_history[_historyIndex], false);
        }
    }

    private async Task LoadDirectoryAsync(string path)
    {
        await LoadDirectoryInternalAsync(path, true);
    }

    private async Task LoadDirectoryInternalAsync(string path, bool addToHistory)
    {
        CancelSearch();
        _isSearchResults = false;
        _searchInput = "";
        
        _isLoading = true;
        _errorMessage = null;
        ClearSelection();
        StateHasChanged();

        try
        {
            HttpResponseMessage response;
            if (path.Equals("::RecycleBin::", StringComparison.OrdinalIgnoreCase))
            {
                response = await Http.GetAsync("api/fileexplorer/recyclebin");
            }
            else
            {
                var uri = $"api/fileexplorer/list?path={Uri.EscapeDataString(path)}&showHidden={_showHidden}";
                response = await Http.GetAsync(uri);
            }

            if (response.IsSuccessStatusCode)
            {
                if (addToHistory)
                {
                    if (_historyIndex < _history.Count - 1)
                    {
                        _history.RemoveRange(_historyIndex + 1, _history.Count - _historyIndex - 1);
                    }
                    if (_history.Count == 0 || _history.Last() != path)
                    {
                        _history.Add(path);
                        _historyIndex = _history.Count - 1;
                    }
                }
                
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                if (path.Equals("::RecycleBin::", StringComparison.OrdinalIgnoreCase))
                {
                    var rbItems = await response.Content.ReadFromJsonAsync<IEnumerable<RecycleBinItem>>(options);
                    _currentItems = rbItems?.Select(i => new FileSystemItem(
                        i.Name,
                        i.Id,
                        FileSystemItemType.File, // Approximation, not great, we'll see
                        i.Size,
                        i.DeletionTime,
                        false,
                        i.OriginalPath,
                        i.DeletionTime
                    )).ToList();
                }
                else
                {
                    var result = await response.Content.ReadFromJsonAsync<WebFileExplorer.Shared.Models.PagedResult<FileSystemItem>>(options);
                    var deserialized = result?.Items;
                    _currentItems = deserialized?.OrderBy(i => i.Type != FileSystemItemType.Folder).ThenBy(i => i.Name).ToList();
                }
                _currentPath = path;
                _addressInput = path;
                _needsKeyboardRegistration = true;
                UpdateBreadcrumbs();
                
                await SaveStateAsync();

                await SyncTreeSelectionAsync(path);

                if (_postLoadSelectionPaths.Any() && _currentItems != null)
                {
                    _selectedItems = _currentItems
                        .Where(i => _postLoadSelectionPaths.Any(p => 
                            string.Equals(p, i.FullPath, StringComparison.OrdinalIgnoreCase)))
                        .ToList();
                    
                    if (_selectedItems.Any())
                    {
                        _focusedItem = _selectedItems.First();
                        _lastClickedItem = _focusedItem;
                    }
                    _postLoadSelectionPaths.Clear();
                }

                if (_pendingSortProperty != null && _currentItems != null)
                {
                    var prop = typeof(FileSystemItem).GetProperty(_pendingSortProperty);
                    if (prop != null)
                    {
                        if (_pendingSortOrder == 1)
                            _currentItems = _currentItems.OrderBy(x => prop.GetValue(x)).ToList();
                        else if (_pendingSortOrder == 2)
                            _currentItems = _currentItems.OrderByDescending(x => prop.GetValue(x)).ToList();
                        
                        try {
                            if (_dataGrid != null)
                            {
                                var col = _dataGrid.ColumnsCollection.FirstOrDefault(c => c.Property == _pendingSortProperty);
                                if (col != null)
                                {
                                    col.SortOrder = _pendingSortOrder == 1 ? Radzen.SortOrder.Ascending : Radzen.SortOrder.Descending;
                                }
                            }
                        } catch { }
                    }
                    _pendingSortProperty = null;
                    _pendingSortOrder = null;
                }

                if (_pendingScrollPosition.HasValue && _pendingScrollPosition.Value > 0)
                {
                    var scrollPos = _pendingScrollPosition.Value;
                    _pendingScrollPosition = null;

                    // Schedule on the renderer so the callback is cancelled when the component
                    // is disposed (via the linked cancellation token below). Avoids Task.Run fire-
                    // and-forget that can execute JS interop after navigation.
                    var token = _lifetimeCts.Token;
                    _ = InvokeAsync(async () =>
                    {
                        try
                        {
                            await Task.Delay(150, token);
                            if (token.IsCancellationRequested) return;

                            if (_viewMode == "List")
                            {
                                await JS.InvokeVoidAsync("eval", token, $"var el = document.querySelector('.rz-data-grid-data'); if (el) el.scrollTop = {scrollPos};");
                            }
                            else
                            {
                                await JS.InvokeVoidAsync("eval", token, $"var el = document.getElementById('file-container'); if (el) el.scrollTop = {scrollPos};");
                            }
                        }
                        catch (OperationCanceledException)
                        {
                            // Component disposed or navigation occurred — expected.
                        }
                        catch (Exception ex)
                        {
                            Console.Error.WriteLine($"Scroll restore failed: {ex.Message}");
                        }
                    });
                }
            }
            else
            {
                if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
                    _errorMessage = "Access Denied: You are not authorized to access this directory.";
                else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
                    _errorMessage = "Directory not found.";
                else if (response.StatusCode == System.Net.HttpStatusCode.NotImplemented && path.Equals("::RecycleBin::", StringComparison.OrdinalIgnoreCase))
                    _errorMessage = "Recycle Bin is unsupported or unavailable on this system.";
                else
                    _errorMessage = $"Error: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load directory {Path}", path);
            _errorMessage = "An unexpected error occurred while loading the directory.";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SyncTreeSelectionAsync(string path)
    {
        if (_treeNodes.Count == 0) return;

        if (path.Equals("::RecycleBin::", StringComparison.OrdinalIgnoreCase))
        {
            _selectedTreeNode = _treeNodes.FirstOrDefault(n => n.Path == "::RecycleBin::");
            return;
        }

        char separator = path.Contains('\\') ? '\\' : '/';

        // Find the matching root node
        TreeNodeObj? rootNode = null;
        foreach (var node in _treeNodes)
        {
            if (node.Path == "::RecycleBin::") continue;
            string rootPath = node.Path.TrimEnd('/', '\\') + separator;
            string testPath = path.TrimEnd('/', '\\') + separator;
            if (testPath.StartsWith(rootPath, StringComparison.OrdinalIgnoreCase))
            {
                rootNode = node;
                break;
            }
        }

        if (rootNode == null) return;

        string rootDir = rootNode.Path.TrimEnd('/', '\\');
        string targetDir = path.TrimEnd('/', '\\');

        if (string.Equals(rootDir, targetDir, StringComparison.OrdinalIgnoreCase))
        {
            _selectedTreeNode = rootNode;
            return;
        }

        // Split path into segments after root
        string relative = targetDir.Substring(rootDir.Length).TrimStart('/', '\\');
        var segments = relative.Split(new[] { '\\', '/' }, StringSplitOptions.RemoveEmptyEntries);

        // Walk down, loading children at each level
        _expandedNodes.Add(rootNode.Path);
        var currentNode = rootNode;

        foreach (var segment in segments)
        {
            // Ensure children are loaded
            if (!currentNode.ChildrenLoaded)
            {
                await LoadTreeNodeChildren(currentNode);
            }

            // Find the child matching this segment
            var child = currentNode.Children.FirstOrDefault(c =>
                c.Name.Equals(segment, StringComparison.OrdinalIgnoreCase));

            if (child == null) break;

            _expandedNodes.Add(child.Path);
            currentNode = child;
        }

        // The last expanded node IS the current folder, so just select it (don't expand it unless user does)
        _selectedTreeNode = currentNode;
        StateHasChanged();
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs.Clear();
        if (string.IsNullOrEmpty(_currentPath)) return;

        char separator = _currentPath!.Contains('\\') ? '\\' : '/';
        var parts = _currentPath.Split(new[] { '\\', '/' }, StringSplitOptions.RemoveEmptyEntries);
        
        var sb = new System.Text.StringBuilder();
        
        if (_currentPath.StartsWith("/"))
        {
            sb.Append('/');
        }
        
        foreach (var part in parts)
        {
            sb.Append(part);
            sb.Append(separator);
            _breadcrumbs.Add((part, sb.ToString()));
        }
    }

    private static readonly string[] _sizes = { "B", "KB", "MB", "GB", "TB" };

    private string FormatSize(long bytes)
    {
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < _sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {_sizes[order]}";
    }


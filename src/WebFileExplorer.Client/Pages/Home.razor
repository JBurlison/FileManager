    private static readonly HashSet<string> _previewExtensions = new(StringComparer.OrdinalIgnoreCase) { ".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp", ".txt", ".json", ".cs", ".md", ".xml", ".html", ".js", ".css", ".log", ".csv", ".ini", ".conf", ".yml", ".yaml" };

    private async Task PreviewOrDownload(FileSystemItem item)
    {
        var ext = GetExtension(item.Name);
        
        if (_previewExtensions.Contains(ext))
        {
            await ShowPreviewDialogAsync(item);
        }
        else
        {
            await DownloadFileAsync(item);
        }
    }

    private async Task ShowPreviewDialogAsync(FileSystemItem item)
    {
        await DialogService.OpenAsync<PreviewDialog>($"Preview: {item.Name}",
            new Dictionary<string, object> { { "FilePath", item.FullPath }, { "FileName", item.Name } },
            new DialogOptions { Width = "80vw", Height = "80vh", Resizable = true, Draggable = true });
    }

    private async Task DownloadFileAsync(FileSystemItem item)
    {
        var uri = $"api/fileexplorer/download?path={Uri.EscapeDataString(item.FullPath)}";
        await JS.InvokeVoidAsync("open", uri, "_blank");
    }

    private void OnItemClick(Microsoft.AspNetCore.Components.Web.MouseEventArgs args, FileSystemItem item)
    {
        _focusedItem = item;

        if (_currentItems == null) return;
        var itemsList = _currentItems as IList<FileSystemItem> ?? _currentItems.ToList();

        if (args.CtrlKey)
        {
            if (_selectedItems.Contains(item))
            {
                _selectedItems.Remove(item);
            }
            else
            {
                _selectedItems.Add(item);
            }
        }
        else if (args.ShiftKey && _lastClickedItem != null)
        {
            int start = itemsList.IndexOf(_lastClickedItem);
            int end = itemsList.IndexOf(item);
            if (start != -1 && end != -1)
            {
                int min = Math.Min(start, end);
                int max = Math.Max(start, end);
                _selectedItems.Clear();
                for (int i = min; i <= max; i++)
                {
                    _selectedItems.Add(itemsList[i]);
                }
            }
        }
        else
        {
            _selectedItems.Clear();
            _selectedItems.Add(item);
            _lastClickedItem = item;
        }
    }

    public class TreeNodeObj
    {
        public string Name { get; set; } = "";
        public string Path { get; set; } = "";
        public bool IsDrive { get; set; }
        public List<TreeNodeObj> Children { get; set; } = new();
        public bool ChildrenLoaded { get; set; }
    }

    private List<TreeNodeObj> _treeNodes = new();

    private bool IsNodeExpanded(object data)
    {
        if (data is TreeNodeObj node) return _expandedNodes.Contains(node.Path);
        return false;
    }

    private TreeNodeObj? _selectedTreeNode;

    private async Task OnTreeNodeClick(TreeNodeObj node)
    {
        _selectedTreeNode = node;
        await LoadDirectoryAsync(node.Path);
    }

    private async Task OnTreeNodeToggle(TreeNodeObj node)
    {
        if (_expandedNodes.Contains(node.Path))
        {
            _expandedNodes.Remove(node.Path);
        }
        else
        {
            _expandedNodes.Add(node.Path);
            if (!node.ChildrenLoaded)
            {
                await LoadTreeNodeChildren(node);
            }
        }
        StateHasChanged();
    }

    private async Task LoadTreeNodeChildren(TreeNodeObj node)
    {
        if (node.Path == "::RecycleBin::") return;
        try
        {
            var uri = $"api/fileexplorer/list?path={Uri.EscapeDataString(node.Path)}&showHidden={_showHidden}";
            var response = await Http.GetAsync(uri);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<WebFileExplorer.Shared.Models.PagedResult<FileSystemItem>>();
                var items = result?.Items;
                if (items != null)
                {
                    node.Children = items
                        .Where(i => i.Type == FileSystemItemType.Folder)
                        .OrderBy(i => i.Name)
                        .Select(d => new TreeNodeObj { Name = d.Name, Path = d.FullPath })
                        .ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load children for tree node {Path}", node.Path);
        }
        node.ChildrenLoaded = true;
    }

    private void OnTreeContextMenu(Microsoft.AspNetCore.Components.Web.MouseEventArgs args, TreeNodeObj? nodeObj)
    {
        if (nodeObj == null) return;

        ClearSelection();
        
        var menuItems = new List<ContextMenuItem>
        {
            new ContextMenuItem { Text = "Open", Value = "Open", Icon = "folder_open" }
        };

        if (!nodeObj.IsDrive)
        {
            menuItems.Add(new ContextMenuItem { Text = "Copy Path", Value = "CopyPath", Icon = "content_copy" });
        }

        if (CanPaste)
        {
            menuItems.Add(new ContextMenuItem { Text = "Paste", Value = "Paste", Icon = "content_paste" });
        }

        ContextMenuService.Open(args, menuItems, async (MenuItemEventArgs e) =>
        {
            try
            {
                var val = e.Value?.ToString();
                switch (val)
                {
                    case "Open":
                        await LoadDirectoryAsync(nodeObj.Path);
                        break;
                    case "CopyPath":
                        await JS.InvokeVoidAsync("navigator.clipboard.writeText", nodeObj.Path);
                        break;
                    case "Paste":
                        if (!string.IsNullOrEmpty(nodeObj.Path))
                        {
                            var oldPath = _currentPath;
                            _currentPath = nodeObj.Path;
                            await PasteItems();
                            _currentPath = oldPath;
                        }
                        break;
                }
                ContextMenuService.Close();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error in context menu action.");
            }
        });
    }

    private void OnContainerContextMenu(Microsoft.AspNetCore.Components.Web.MouseEventArgs args)
    {
        // Use a generic context menu for the free space
        ClearSelection();
        
        var menuItems = new List<ContextMenuItem>
        {
            new ContextMenuItem { Text = "Paste", Value = "Paste", Icon = "content_paste", Disabled = !CanPaste },
            new ContextMenuItem { Text = "New Folder", Value = "NewFolder", Icon = "create_new_folder", Disabled = string.IsNullOrEmpty(_currentPath) }
        };

        ContextMenuService.Open(args, menuItems, async (MenuItemEventArgs e) =>
        {
            try
            {
                var val = e.Value?.ToString();
                switch (val)
                {
                    case "Paste": await PasteItems(); break;
                    case "NewFolder": await CreateFolderDialog(); break;
                }
                ContextMenuService.Close();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error executing context menu.");
            }
        });
    }

    private void OnRowRender(RowRenderEventArgs<FileSystemItem> args)
    {
        if (args.Data != null)
        {
            args.Attributes.Add("oncontextmenu", Microsoft.AspNetCore.Components.EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.MouseEventArgs>(this, e => OnContextMenu(e, args.Data)));
            args.Attributes.Add("oncontextmenu:preventDefault", true);
            args.Attributes.Add("oncontextmenu:stopPropagation", true);
        }
    }

    private void OnContextMenu(Microsoft.AspNetCore.Components.Web.MouseEventArgs args, FileSystemItem item)
    {
        if (!_selectedItems.Contains(item))
        {
            _selectedItems.Clear();
            _selectedItems.Add(item);
            _focusedItem = item;
            _lastClickedItem = item;
            StateHasChanged();
        }

        var menuItems = new List<ContextMenuItem>
        {
            new ContextMenuItem { Text = "Open", Value = "Open", Icon = "open_in_new" },
            new ContextMenuItem { Text = "Download", Value = "Download", Icon = "download", Disabled = item.Type == FileSystemItemType.Folder },
            new ContextMenuItem { Text = "Preview", Value = "Preview", Icon = "visibility", Disabled = item.Type == FileSystemItemType.Folder },
            new ContextMenuItem { Text = "Cut", Value = "Cut", Icon = "content_cut", Disabled = !CanCut },
            new ContextMenuItem { Text = "Copy", Value = "Copy", Icon = "content_copy", Disabled = !CanCopy },
            new ContextMenuItem { Text = "Paste", Value = "Paste", Icon = "content_paste", Disabled = !CanPaste },
            new ContextMenuItem { Text = "Rename", Value = "Rename", Icon = "edit", Disabled = !CanRename },
            new ContextMenuItem { Text = "Delete", Value = "Delete", Icon = "delete", Disabled = !CanDelete },
            new ContextMenuItem { Text = "Compress to ZIP file", Value = "Compress", Icon = "folder_zip" },
            new ContextMenuItem { Text = "Extract All", Value = "Extract", Icon = "unarchive", Disabled = !(item.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase)) },
            new ContextMenuItem { Text = "Properties", Value = "Properties", Icon = "info" }
        };

        ContextMenuService.Open(args, menuItems, async (MenuItemEventArgs e) =>
        {
            try
            {
                var val = e.Value?.ToString();
                switch (val)
                {
                    case "Open": await OnItemDoubleClick(item); break;
                    case "Download": await DownloadFileAsync(item); break;
                    case "Preview": await ShowPreviewDialogAsync(item); break;
                    case "Cut": CutSelected(); break;
                    case "Copy": CopySelected(); break;
                    case "Paste": await PasteItems(); break;
                    case "Rename": await RenameDialog(); break;
                    case "Delete": await DeleteSelected(false); break;
                    case "Compress": await CompressSelected(); break;
                    case "Extract": await ExtractSelected(item); break;
                    case "Properties": await ShowPropertiesDialogAsync(item); break;
                }
                ContextMenuService.Close();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error executing context menu action");
            }
        });
    }

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs args)
    {
        if (_currentItems == null || !_currentItems.Any()) return;

        var itemsList = _currentItems as IList<FileSystemItem> ?? _currentItems.ToList();
        
        if (string.Equals(args.Key, "f5", StringComparison.OrdinalIgnoreCase))
        {
            if (!string.IsNullOrEmpty(_currentPath)) {
                await LoadDirectoryAsync(_currentPath);
            }
            return;
        }

        if (string.Equals(args.Key, "f2", StringComparison.OrdinalIgnoreCase))
        {
            await RenameDialog();
            return;
        }
        
        if (args.CtrlKey && string.Equals(args.Key, "c", StringComparison.OrdinalIgnoreCase))
        {
            CopySelected();
            return;
        }
        
        if (args.CtrlKey && string.Equals(args.Key, "x", StringComparison.OrdinalIgnoreCase))
        {
            CutSelected();
            return;
        }
        
        if (args.CtrlKey && string.Equals(args.Key, "v", StringComparison.OrdinalIgnoreCase))
        {
            await PasteItems();
            return;
        }

        if (args.CtrlKey && args.ShiftKey && string.Equals(args.Key, "n", StringComparison.OrdinalIgnoreCase))
        {
            await CreateFolderDialog();
            return;
        }

        if (args.AltKey && string.Equals(args.Key, "arrowleft", StringComparison.OrdinalIgnoreCase))
        {
            await NavigateBack();
            return;
        }

        if (args.AltKey && string.Equals(args.Key, "arrowright", StringComparison.OrdinalIgnoreCase))
        {
            await NavigateForward();
            return;
        }

        if (string.Equals(args.Key, "backspace", StringComparison.OrdinalIgnoreCase))
        {
            await NavigateBack();
            return;
        }

        if (args.AltKey && string.Equals(args.Key, "arrowup", StringComparison.OrdinalIgnoreCase))
        {
            await NavigateUp();
            return;
        }

        if ((args.ShiftKey && string.Equals(args.Key, "f10", StringComparison.OrdinalIgnoreCase)) ||
            string.Equals(args.Key, "ContextMenu", StringComparison.OrdinalIgnoreCase))
        {
            if (_focusedItem != null)
            {
                OnContextMenu(new Microsoft.AspNetCore.Components.Web.MouseEventArgs(), _focusedItem);
            }
            else
            {
                OnContainerContextMenu(new Microsoft.AspNetCore.Components.Web.MouseEventArgs());
            }
            return;
        }

        if (args.Key == "Delete")
        {
            await DeleteSelected(args.ShiftKey);
            return;
        }
        
        if (args.Key == "Enter" && _focusedItem != null)
        {
            await OnItemDoubleClick(_focusedItem);
            return;
        }
        
        if (args.CtrlKey && string.Equals(args.Key, "a", StringComparison.OrdinalIgnoreCase))
        {
            _selectedItems.Clear();
            if (_selectedItems is List<FileSystemItem> list)
            {
                list.AddRange(itemsList);
            }
            else
            {
                foreach (var item in itemsList)
                {
                    _selectedItems.Add(item);
                }
            }
            return;
        }

        int columns = _viewMode == "Details" || _viewMode == "List" ? ColumnsDefaultList 
            : (_viewMode == "SmallIcons" ? ColumnsSmallIcons 
            : (_viewMode == "MediumIcons" ? ColumnsMediumIcons : ColumnsLargeIcons));
        
        if (args.Key is "ArrowUp" or "ArrowDown" or "ArrowLeft" or "ArrowRight" or "Home" or "End" or "PageUp" or "PageDown")
        {
            if (_focusedItem == null)
            {
                _focusedItem = itemsList.First();
                if (!args.ShiftKey)
                {
                    _lastClickedItem = _focusedItem;
                    _selectedItems.Clear();
                    _selectedItems.Add(_focusedItem);
                }
            }
            else
            {
                int currentIndex = itemsList.IndexOf(_focusedItem);
                int nextIndex = currentIndex;

                if (args.Key == "ArrowUp") nextIndex = Math.Max(0, currentIndex - columns);
                if (args.Key == "ArrowDown") nextIndex = Math.Min(itemsList.Count - 1, currentIndex + columns);
                if (args.Key == "ArrowLeft") nextIndex = Math.Max(0, currentIndex - 1);
                if (args.Key == "ArrowRight") nextIndex = Math.Min(itemsList.Count - 1, currentIndex + 1);
                if (args.Key == "Home") nextIndex = 0;
                if (args.Key == "End") nextIndex = itemsList.Count - 1;
                
                // Roughly 5 rows per page skip
                int pageSize = columns * 5;
                if (args.Key == "PageUp") nextIndex = Math.Max(0, currentIndex - pageSize);
                if (args.Key == "PageDown") nextIndex = Math.Min(itemsList.Count - 1, currentIndex + pageSize);

                if (nextIndex != currentIndex)
                {
                    _focusedItem = itemsList[nextIndex];

                    if (args.ShiftKey)
                    {
                        if (_lastClickedItem == null) _lastClickedItem = itemsList[currentIndex];
                        
                        int start = itemsList.IndexOf(_lastClickedItem);
                        int end = itemsList.IndexOf(_focusedItem);
                        int min = Math.Min(start, end);
                        int max = Math.Max(start, end);
                        
                        _selectedItems.Clear();
                        for (int i = min; i <= max; i++)
                        {
                            _selectedItems.Add(itemsList[i]);
                        }
                    }
                    else
                    {
                        _lastClickedItem = _focusedItem;
                        _selectedItems.Clear();
                        _selectedItems.Add(_focusedItem);
                    }
                }
            }
            return;
        }

        if (args.Key.Length == 1 && !args.CtrlKey && !args.AltKey)
        {
            if ((DateTime.Now - _lastTypeTime).TotalMilliseconds > 1000)
            {
                _typeBuffer = "";
            }
            _typeBuffer += args.Key.ToLower();
            _lastTypeTime = DateTime.Now;

            var match = itemsList.FirstOrDefault(i => i.Name.ToLower().StartsWith(_typeBuffer));
            if (match != null)
            {
                _focusedItem = match;
                _lastClickedItem = match;
                _selectedItems.Clear();
                _selectedItems.Add(match);
            }
        }
    }

    private static readonly HashSet<string> _imageExtensions = new(StringComparer.OrdinalIgnoreCase) { ".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp", ".svg" };

    private bool IsImageFile(FileSystemItem item)
    {
        if (item.Type != FileSystemItemType.File) return false;
        var ext = GetExtension(item.Name);
        return _imageExtensions.Contains(ext);
    }

    private string GetIconForItem(FileSystemItem item)
    {
        if (item.Type == FileSystemItemType.Folder) return "folder";
        if (item.Type == FileSystemItemType.Archive) return "folder_zip";
        return "insert_drive_file";
    }

    private string GetIconClass(FileSystemItem item)
    {
        if (item.Type == FileSystemItemType.Folder) return "icon-folder";
        if (item.Type == FileSystemItemType.Archive) return "icon-archive";
        return "icon-file";
    }

    private string GetFileName(string path)
    {
        if (string.IsNullOrEmpty(path)) return path;
        int lastSlash = Math.Max(path.LastIndexOf('/'), path.LastIndexOf('\\'));
        return lastSlash >= 0 ? path.Substring(lastSlash + 1) : path;
    }

    private string GetDirectoryName(string path)
    {
        if (string.IsNullOrEmpty(path)) return string.Empty;
        var normalized = path.TrimEnd('/', '\\');
        int lastSlash = Math.Max(normalized.LastIndexOf('/'), normalized.LastIndexOf('\\'));
        if (lastSlash <= 0) return string.Empty;
        if (lastSlash == 2 && normalized[1] == ':') return normalized.Substring(0, 3);
        return normalized.Substring(0, lastSlash);
    }

    private string CombinePaths(string path1, string path2)
    {
        if (string.IsNullOrEmpty(path1)) return path2;
        if (string.IsNullOrEmpty(path2)) return path1;
        var p1 = path1.TrimEnd('/', '\\');
        var p2 = path2.TrimStart('/', '\\');
        char sep = p1.Contains('\\') ? '\\' : '/';
        return p1 + sep + p2;
    }

    private string GetFileNameWithoutExtension(string path)
    {
        var fileName = GetFileName(path);
        int lastDot = fileName.LastIndexOf('.');
        return lastDot > 0 ? fileName.Substring(0, lastDot) : fileName;
    }

    private string GetExtension(string path)
    {
        var fileName = GetFileName(path);
        int lastDot = fileName.LastIndexOf('.');
        return lastDot >= 0 ? fileName.Substring(lastDot) : string.Empty;
    }

    private async Task ShowPropertiesDialogAsync(FileSystemItem item)
    {
        try
        {
            var targetItems = _selectedItems.Contains(item) ? _selectedItems.ToList() : new List<FileSystemItem> { item };
            if (!targetItems.Any()) return;

            string uri = "api/fileexplorer/properties";
            Result<FileProperties>? responseResult;

            if (targetItems.Count == 1)
            {
                var queryUri = $"{uri}?path={Uri.EscapeDataString(targetItems[0].FullPath)}";
                responseResult = await Http.GetFromJsonAsync<Result<FileProperties>>(queryUri);
            }
            else
            {
                var response = await Http.PostAsJsonAsync(uri, targetItems.Select(i => i.FullPath).ToArray());
                responseResult = await response.Content.ReadFromJsonAsync<Result<FileProperties>>();
            }

            if (responseResult != null && responseResult.IsSuccess && responseResult.Value != null)
            {
                var props = responseResult.Value;
                await DialogService.OpenAsync("Properties", ds =>
                    @<div style="padding: 10px; overflow-y: auto; max-height: 400px;">
                        <div style="margin-bottom: 8px;"><strong>Name:</strong> @props.Name</div>
                        <div style="margin-bottom: 8px;"><strong>Type:</strong> @props.Type</div>
                        <div style="margin-bottom: 8px;"><strong>Location:</strong> @props.Location</div>
                        <div style="margin-bottom: 8px;">
                            <strong>Size:</strong> @($"{FormatSize(props.Size)} ({props.Size:N0} bytes)")
                        </div>
                        <div style="margin-bottom: 8px;">
                            <strong>Contains:</strong> @props.FileCount Files, @props.FolderCount Folders
                        </div>
                        <hr />
                        @if (props.Created.HasValue)
                        {
                            <div style="margin-bottom: 8px;"><strong>Created:</strong> @props.Created.Value.ToLocalTime()</div>
                        }
                        @if (props.LastModified.HasValue)
                        {
                            <div style="margin-bottom: 8px;"><strong>Modified:</strong> @props.LastModified.Value.ToLocalTime()</div>
                        }
                        @if (props.Accessed.HasValue)
                        {
                            <div style="margin-bottom: 8px;"><strong>Accessed:</strong> @props.Accessed.Value.ToLocalTime()</div>
                        }
                        <hr />
                        <div style="margin-bottom: 8px;"><strong>Attributes:</strong></div>
                        <div style="margin-left: 10px;">
                            <div style="margin-bottom: 4px;">
                                <RadzenCheckBox Value=@(props.IsReadOnly ?? false) Disabled="true" TriState="true" />
                                <span class="ms-2">Read-only @(props.IsReadOnly == null ? "(Mixed)" : "")</span>
                            </div>
                            <div style="margin-bottom: 4px;">
                                <RadzenCheckBox Value=@(props.IsHidden ?? false) Disabled="true" TriState="true" />
                                <span class="ms-2">Hidden @(props.IsHidden == null ? "(Mixed)" : "")</span>
                            </div>
                            <div style="margin-bottom: 4px;">
                                <RadzenCheckBox Value=@(props.IsSystem ?? false) Disabled="true" TriState="true" />
                                <span class="ms-2">System @(props.IsSystem == null ? "(Mixed)" : "")</span>
                            </div>
                            <div style="margin-bottom: 20px;">
                                <RadzenCheckBox Value=@(props.IsArchive ?? false) Disabled="true" TriState="true" />
                                <span class="ms-2">Archive @(props.IsArchive == null ? "(Mixed)" : "")</span>
                            </div>
                        </div>
                        <div class="row pt-3">
                            <div class="col-md-12 text-right">
                                <RadzenButton Text="OK" Click="@(args => ds.Close())" Style="width: 120px" class="ms-1" />
                            </div>
                        </div>
                    </div>, new DialogOptions() { Width = "500px", Height = "500px" });
            }
            else
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = responseResult?.ErrorMessage ?? "Could not load properties." });
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to get properties");
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = "Failed to load properties." });
        }
    }

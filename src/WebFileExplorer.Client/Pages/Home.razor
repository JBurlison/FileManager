    private async Task RestoreSelected()
    {
        if (!CanRestore) return;
        
        var itemsToRestore = _selectedItems.Count > 0 ? _selectedItems.ToList() : new List<FileSystemItem> { _focusedItem! };
        
        _isLoading = true;
        StateHasChanged();

        try
        {
            int successCount = 0;
            int failedCount = 0;
            foreach (var item in itemsToRestore)
            {
                var response = await Http.PostAsync($"api/fileexplorer/recyclebin/restore?id={Uri.EscapeDataString(item.FullPath)}", null);
                if (response.IsSuccessStatusCode)
                {
                    successCount++;
                }
                else
                {
                    failedCount++;
                }
            }
            
            if (successCount > 0)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Restored", $"Successfully restored {successCount} item(s).");
                await LoadDirectoryAsync(_currentPath!);
            }
            if (failedCount > 0)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Restore Failed", $"{failedCount} item(s) failed.");
            }
            else if (successCount == 0)
            {
                 NotificationService.Notify(NotificationSeverity.Error, "Error", "Failed to restore item(s).");
            }
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }


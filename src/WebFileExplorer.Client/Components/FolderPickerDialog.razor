@using WebFileExplorer.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject DialogService DialogService

<RadzenStack Gap="1rem">
    <div class="d-flex align-items-center mb-2">
        <RadzenButton Icon="arrow_upward" Click="@NavigateUp" Class="rz-mr-2" Size="ButtonSize.Small" title="Up" />
        <RadzenTextBox @bind-Value="@_currentPath" style="flex: 1" Disabled="true" />
    </div>

    @if (_isLoading)
    {
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Style="width:100%" />
    }
    else
    {
        <RadzenDataGrid Data="@_folders" TItem="FileSystemItem"
                        RowDoubleClick="@(async args => await LoadDirectoryAsync(args.Data!.FullPath))"
                        SelectionMode="DataGridSelectionMode.Single"
                        @bind-Value=@_selectedItems
                        Style="height: 300px">
            <Columns>
                <RadzenDataGridColumn TItem="FileSystemItem" Property="Name" Title="Name">
                    <Template Context="item">
                        <RadzenIcon Icon="folder" Style="vertical-align: middle; margin-right: 8px;" />
                        @item.Name
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
        <RadzenButton Text="Select Current" Click="@(() => DialogService.Close(_currentPath))" ButtonStyle="ButtonStyle.Primary" Style="width: 150px" />
        <RadzenButton Text="Select Highlighted" Click="@(() => DialogService.Close(_selectedItems.FirstOrDefault()?.FullPath ?? _currentPath))" ButtonStyle="ButtonStyle.Primary" Style="width: 150px" Disabled="@(!_selectedItems.Any())" />
        <RadzenButton Text="Cancel" Click="@(() => DialogService.Close(null))" ButtonStyle="ButtonStyle.Light" Style="width: 100px" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public string InitialPath { get; set; } = string.Empty;

    private string _currentPath = string.Empty;
    private List<FileSystemItem> _folders = new();
    private IList<FileSystemItem> _selectedItems = new List<FileSystemItem>();
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDirectoryAsync(InitialPath);
    }

    private async Task LoadDirectoryAsync(string path)
    {
        _isLoading = true;
        _currentPath = path ?? string.Empty;
        _selectedItems.Clear();
        _folders = new List<FileSystemItem>();

        try
        {
            if (string.IsNullOrEmpty(_currentPath))
            {
                // No path yet — show authorized roots.
                var roots = await Http.GetFromJsonAsync<List<DriveItem>>("api/fileexplorer/roots");
                if (roots != null)
                {
                    _folders = roots
                        .Select(r => new FileSystemItem(r.Name, r.RootDirectory, FileSystemItemType.Folder, 0, DateTime.MinValue, false))
                        .OrderBy(x => x.Name)
                        .ToList();
                }
                return;
            }

            var uri = $"api/fileexplorer/list?path={Uri.EscapeDataString(_currentPath)}&showHidden=false";
            var response = await Http.GetAsync(uri);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PagedResult<FileSystemItem>>();
                if (result?.Items != null)
                {
                    _folders = result.Items
                        .Where(x => x.Type == FileSystemItemType.Folder)
                        .OrderBy(x => x.Name)
                        .ToList();
                }
            }
        }
        catch
        {
            // Ignore — dialog stays usable even if a listing fails.
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task NavigateUp()
    {
        if (string.IsNullOrEmpty(_currentPath))
        {
            return;
        }

        string? parent = null;
        try
        {
            parent = System.IO.Path.GetDirectoryName(_currentPath);
        }
        catch
        {
            parent = null;
        }

        await LoadDirectoryAsync(parent ?? string.Empty);
    }
}
